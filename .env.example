# Copy to .env and fill in your values
# .env is gitignored — never commit real keys

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic
LLM_MODEL=qwen3.5-plus

# Alibaba DashScope (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# OR OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# Database
# Preferred: full SQLAlchemy URL, so switching SQLite / PostgreSQL / MySQL only needs config changes.
# Examples:
# SWARMMIND_DATABASE_URL=sqlite:///swarmmind.db
# SWARMMIND_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/swarmmind
# SWARMMIND_DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/swarmmind
SWARMMIND_DATABASE_URL=sqlite:///swarmmind.db

# Schema initialization is Alembic-only: app startup applies migrations to head.

# Legacy SQLite-only fallback. Only used when SWARMMIND_DATABASE_URL is unset.
# SWARMMIND_DB_PATH=swarmmind.db

# Supervisor API
SWARMMIND_API_HOST=127.0.0.1
SWARMMIND_API_PORT=8000

# Action proposal timeout (seconds)
ACTION_TIMEOUT_SECONDS=300

# DeerFlow configuration (optional — enables GeneralAgent)
# Install with: uv sync --extra deerflow
# DEER_FLOW_CONFIG_PATH=/path/to/deer-flow/backend/config.yaml
# DEER_FLOW_SKILLS_PATH=/path/to/deer-flow/backend/data/skills

# ============================================
# uv Package Manager Configuration
# ============================================
# For China users: uncomment to use Tsinghua PyPI mirror for faster downloads
# UV_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple/
